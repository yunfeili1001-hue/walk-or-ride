# Copy to .env and fill in your keys
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key
# Google Cloud Console — restrict this key to HTTP referrers, e.g.:
#   http://localhost:*/*
#   https://hcde438-final-b5a03.web.app/*
# Enable: Maps JavaScript API, Geocoding API, Maps Embed API, Distance Matrix API
VITE_TRANSITLAND_KEY=your_transitland_api_key
VITE_OPENWEATHER_KEY=your_openweather_api_key

# Firebase — from Project Settings > General > Your apps (Web)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
# Optional — for Google Analytics
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
